#!/usr/bin/env bash
# lint_no_hardcoded_balance_constants.sh.template
#
# REUSABLE TEMPLATE — per-system hardcoded-constant lint (TR-balance-data-010).
#
# Purpose: enforce ADR-0006 §Decision 7 + ADR-0012 §6 — balance constants
# (BASE_CEILING, P_MULT_COMBINED_CAP, etc.) must NOT appear as `const X = ...`
# declarations in consumer .gd files. Their values live exclusively in
# assets/data/balance/balance_entities.json, read via BalanceConstants.get_const(key).
#
# ## Origin
#
# Generalized from tools/ci/lint_damage_calc_no_hardcoded_constants.sh
# (AC-DC-48 precedent for the damage_calc consumer; landed via damage-calc
# story-006b PR #65 / 2026-04-27). Story-003 (balance-data epic, 2026-05-01)
# extracts this template for reuse across future consumers.
#
# ## How to instantiate (Approach B per balance-data/story-003 AC-1)
#
# Approach B: instance-per-consumer (mirrors AC-DC-48's pattern). Revisit
# Approach A (single parameterized script) when 3+ consumers exist and DRY
# value exceeds the cost of CLI arg validation.
#
# Steps:
#   1. Copy this template to a per-consumer file:
#        cp tools/ci/lint_no_hardcoded_balance_constants.sh.template \
#           tools/ci/lint_<consumer>_no_hardcoded_constants.sh
#   2. Customize the 2 instantiation points marked `# INSTANTIATION:`:
#        TARGET   — path or glob for the .gd file(s) the consumer owns
#        PATTERN  — regex alternation of the constant names this consumer is
#                   forbidden to declare locally (Option β per story-003 —
#                   hardcoded subset; Option α jq-runtime parsing deferred
#                   until jq is added to .github/workflows/tests.yml).
#   3. Add the new lint step to .github/workflows/tests.yml in the gdunit4
#      job, alongside the existing AC-DC-48 step (Option (a) extension per
#      story-003 — single gdunit4 lane keeps step count low).
#
# ## Exit codes (story-008 codified)
#
#   0  — clean (no hardcoded const declarations found)
#   1  — domain failure: violation found (prints offending lines; CI fails)
#   ≥2 — tool failure: lint infrastructure error (e.g., grep crash, missing target)
#
# ## Story-008 silent-fail antipattern guard
#
# DO NOT use the `var=$(grep ...) || true` + `[ -n "$var" ]` pattern — it
# conflates tool-crash (exit ≥2) with domain-fail (exit 1). Capturing into a
# variable + `|| true` swallows the crash exit code, so the `if [ -n "$var" ]`
# check would never see it. The lint would silently "pass" on tool failure.
#
# CORRECT pattern (used below): direct `if grep -E PATTERN FILE; then ... fi`.
# - grep exit 0 (match found) → if-block runs → exit 1 (domain failure)
# - grep exit 1 (no match)    → if-block skipped → continue to PASS
# - grep exit ≥2 (crash)      → propagates via `set -euo pipefail` as tool failure
#
# Cross-references:
#   - .claude/rules/godot-4x-gotchas.md (general Godot/GdUnit4 gotchas)
#   - .claude/rules/tooling-gotchas.md TG-1 (gh CLI fork-vs-upstream)
#   - tools/ci/lint_damage_calc_no_hardcoded_constants.sh (canonical instance)
#   - production/epics/damage-calc/story-008-determinism-engine-pin-cross-platform.md
#     (silent-fail antipattern codification)
#
# Usage: bash tools/ci/lint_<consumer>_no_hardcoded_constants.sh

set -euo pipefail

# INSTANTIATION 1 — target file(s) the consumer owns.
# Single file: TARGET="src/feature/<system>/<file>.gd"
# Directory:   TARGET_DIR="src/<layer>/<system>" + use `grep -r --include="*.gd"`
TARGET="<TODO: path/to/consumer.gd>"

if [ ! -f "$TARGET" ]; then
  echo "ERROR: $TARGET not found. Run from the project root." >&2
  exit 2
fi

# INSTANTIATION 2 — regex alternation of forbidden const names.
# Subset of balance_entities.json keys relevant to this consumer's domain
# (Option β per balance-data/story-003 — hardcoded subset).
PATTERN="const (<TODO: KEY_1|KEY_2|KEY_3>) "

if grep -nE "$PATTERN" "$TARGET"; then
  echo "" >&2
  echo "FAIL: hardcoded balance constants found in $TARGET (TR-balance-data-010)." >&2
  echo "Move the literal value to assets/data/balance/balance_entities.json and" >&2
  echo "read it via BalanceConstants.get_const(\"KEY\") per ADR-0006 §Decision 7." >&2
  exit 1
fi

echo "PASS: no hardcoded balance constants in $TARGET (TR-balance-data-010)."
exit 0
